{
  "name": "vibe-transcription",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write eslint.config.mjs .prettierrc.json .vscode/settings.json package.json playwright.config.ts src tests tsconfig.json tsconfig.test.json vite.config.ts",
    "format:check": "prettier --check eslint.config.mjs .prettierrc.json .vscode/settings.json package.json playwright.config.ts src tests tsconfig.json tsconfig.test.json vite.config.ts",
    "preview": "vite preview",
    "static": "vue-tsc -b && vite build && vite preview",
    "test": "bunx playwright test --project=fast",
    "test:backend:isolated": "bun run scripts/test-backend-isolated.mjs",
    "test:slow": "bunx playwright test --project=slow",
    "test:all": "bunx playwright test",
    "test:unit": "vitest run",
    "benchmark": "bunx playwright test --project=benchmark"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "idb": "^8.0.3",
    "vue": "^3.5.31"
  }
}
